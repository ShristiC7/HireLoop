{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "node -r dotenv/config ../../node_modules/.bin/drizzle-kit push --config ./drizzle.config.ts dotenv_config_path=../../.env",
    "seed:admin": "node -r dotenv/config ../../node_modules/.bin/tsx src/seedAdmin.ts dotenv_config_path=../../.env"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.9",
    "tsx": "catalog:"
  }
}
