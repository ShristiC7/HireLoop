generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS  (fixed value sets used across tables)
// ─────────────────────────────────────────────

enum Role {
  STUDENT
  RECRUITER
  ADMIN
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW_SCHEDULED
  OFFER
  REJECTED
}

enum JobStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentType {
  JOB_LISTING
  STUDENT_PREMIUM
}

enum RecruiterStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// ─────────────────────────────────────────────
// CORE USER TABLE
// Base authentication for all 3 roles
// ─────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  role            Role
  isEmailVerified Boolean   @default(false)
  isActive        Boolean   @default(true)
  emailVerifyToken String?
  passwordResetToken String?
  passwordResetExpiry DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations - one user has one profile per role
  studentProfile  StudentProfile?
  recruiterProfile RecruiterProfile?
  adminProfile    AdminProfile?
  refreshTokens   RefreshToken[]

  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────────
// JWT REFRESH TOKEN STORE
// Tracks active sessions for secure logout
// ─────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// STUDENT PROFILE
// Extended info about the student beyond login
// ─────────────────────────────────────────────

model StudentProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  firstName       String
  lastName        String
  phone           String?
  gender          Gender?
  dateOfBirth     DateTime?
  avatarUrl       String?

  // Academic info
  college         String
  department      String
  degree          String
  graduationYear  Int
  cgpa            Float?
  rollNumber      String?

  // Career info
  skills          String[]    // array of skill strings e.g. ["React", "Python"]
  bio             String?
  linkedinUrl     String?
  githubUrl       String?
  portfolioUrl    String?

  // Premium feature flag
  isPremium       Boolean  @default(false)
  premiumExpiresAt DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumes         Resume[]
  applications    Application[]
  mockInterviews  MockInterview[]
  aiAnalyses      ResumeAnalysis[]

  @@map("student_profiles")
}

// ─────────────────────────────────────────────
// RESUME
// A student can have multiple versions
// ─────────────────────────────────────────────

model Resume {
  id              String   @id @default(uuid())
  studentId       String
  title           String   @default("My Resume")
  fileUrl         String?  // URL to uploaded PDF
  filePublicId    String?  // Cloudinary public ID for deletion
  isDefault       Boolean  @default(false)

  // Resume builder data (structured JSON)
  // Contains: education[], experience[], projects[], certifications[], skills[]
  builderData     Json?

  atsScore        Float?   // Last computed ATS score (0-100)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student         StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  analyses        ResumeAnalysis[]
  applications    Application[]

  @@map("resumes")
}

// ─────────────────────────────────────────────
// RESUME ANALYSIS
// AI-generated analysis result per resume
// ─────────────────────────────────────────────

model ResumeAnalysis {
  id              String   @id @default(uuid())
  resumeId        String
  studentId       String
  jobId           String?  // optional: compared against a specific job

  atsScore        Float
  matchScore      Float?   // Resume ↔ Job match %
  missingKeywords String[]
  strengths       String[]
  improvements    String[]
  grammarIssues   String[]
  structureScore  Float?
  fullReport      Json     // full AI output stored as JSON

  createdAt       DateTime @default(now())

  resume          Resume        @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  student         StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  job             Job?          @relation(fields: [jobId], references: [id])

  @@map("resume_analyses")
}

// ─────────────────────────────────────────────
// RECRUITER PROFILE
// Company info + approval status by admin
// ─────────────────────────────────────────────

model RecruiterProfile {
  id              String          @id @default(uuid())
  userId          String          @unique
  firstName       String
  lastName        String
  phone           String?
  designation     String?

  // Company details
  companyName     String
  companyWebsite  String?
  companyLogo     String?
  companySize     String?
  industry        String?
  companyDescription String?

  status          RecruiterStatus @default(PENDING)
  rejectionReason String?
  approvedAt      DateTime?
  approvedBy      String?         // admin user ID

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs            Job[]
  payments        Payment[]

  @@map("recruiter_profiles")
}

// ─────────────────────────────────────────────
// ADMIN PROFILE
// Placement cell officers
// ─────────────────────────────────────────────

model AdminProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  firstName   String
  lastName    String
  phone       String?
  designation String?
  college     String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

// ─────────────────────────────────────────────
// JOB POSTING
// Created by recruiters, filtered by admin rules
// ─────────────────────────────────────────────

model Job {
  id              String    @id @default(uuid())
  recruiterId     String
  title           String
  description     String
  responsibilities String?
  requirements    String?

  // Eligibility filters
  minCgpa         Float?
  eligibleBranches String[]    // e.g. ["CSE", "ECE", "IT"]
  eligibleDegrees  String[]    // e.g. ["B.Tech", "MCA"]
  graduationYear  Int?

  // Job details
  location        String?
  isRemote        Boolean   @default(false)
  jobType         String?   // Full-time, Internship, Contract
  salary          String?   // e.g. "12 LPA" or "25,000/month"
  skills          String[]  // Required skills

  status          JobStatus @default(DRAFT)
  deadline        DateTime?
  maxApplications Int?

  // AI keywords extracted from JD for matching
  extractedKeywords String[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  recruiter       RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  applications    Application[]
  interviews      Interview[]
  resumeAnalyses  ResumeAnalysis[]
  payment         Payment?

  @@index([status, deadline])
  @@map("jobs")
}

// ─────────────────────────────────────────────
// APPLICATION
// Student applies to a job
// ─────────────────────────────────────────────

model Application {
  id              String            @id @default(uuid())
  studentId       String
  jobId           String
  resumeId        String?

  status          ApplicationStatus @default(APPLIED)
  coverLetter     String?           // AI-generated or manually typed
  recruiterNotes  String?           // Internal notes by recruiter

  appliedAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  student         StudentProfile    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  job             Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume          Resume?           @relation(fields: [resumeId], references: [id])
  interviews      Interview[]

  @@unique([studentId, jobId]) // One application per job per student
  @@map("applications")
}

// ─────────────────────────────────────────────
// INTERVIEW
// Scheduled by recruiter for an application
// ─────────────────────────────────────────────

model Interview {
  id              String          @id @default(uuid())
  applicationId   String
  jobId           String
  scheduledAt     DateTime
  duration        Int             @default(60) // minutes
  mode            String          @default("Online") // Online / In-person
  meetLink        String?
  venue           String?
  instructions    String?
  status          InterviewStatus @default(SCHEDULED)
  feedback        String?         // Post-interview feedback from recruiter
  result          String?         // Pass / Fail / On-hold

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  job             Job         @relation(fields: [jobId], references: [id])

  @@map("interviews")
}

// ─────────────────────────────────────────────
// AI MOCK INTERVIEW
// Student practices with AI interviewer
// ─────────────────────────────────────────────

model MockInterview {
  id          String   @id @default(uuid())
  studentId   String
  jobRole     String   // e.g. "Software Engineer", "Data Analyst"
  jobId       String?  // optional context
  resumeId    String?

  questions   Json     // array of {question, answer, aiScore, aiFeedback}
  overallScore Float?
  overallFeedback String?
  duration    Int?     // seconds taken

  completedAt DateTime?
  createdAt   DateTime @default(now())

  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("mock_interviews")
}

// ─────────────────────────────────────────────
// PAYMENT
// Tracks recruiter job listing fees & student premium
// ─────────────────────────────────────────────

model Payment {
  id              String        @id @default(uuid())
  userId          String
  type            PaymentType
  status          PaymentStatus @default(PENDING)
  amount          Float
  currency        String        @default("INR")

  // Gateway details
  gateway         String?       // "razorpay" | "stripe"
  gatewayOrderId  String?
  gatewayPaymentId String?
  gatewaySignature String?

  // Linked entity
  recruiterId     String?
  jobId           String?       @unique

  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  recruiter       RecruiterProfile? @relation(fields: [recruiterId], references: [id])
  job             Job?              @relation(fields: [jobId], references: [id])

  @@map("payments")
}

// ─────────────────────────────────────────────
// ANNOUNCEMENT
// Admin broadcasts to all students
// ─────────────────────────────────────────────

model Announcement {
  id          String   @id @default(uuid())
  title       String
  content     String
  isPinned    Boolean  @default(false)
  targetRole  Role?    // null = everyone
  expiresAt   DateTime?
  createdBy   String   // admin user ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("announcements")
}
