# ==============================================================================
# HireLoop Platform — Centralized Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.
#
# This is the SINGLE SOURCE OF TRUTH for all external service credentials.
# Every key used anywhere in the platform is listed here with documentation.
# ==============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# 1. DATABASE — Supabase PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────
# Get from: https://supabase.com → Your Project → Settings → Database → URI
# Use the "Session Pooler" URL (port 5432) for best compatibility.
# Format: postgresql://postgres.[ref]:[password]@[host]:5432/postgres
#
SUPABASE_DATABASE_URL=postgresql://postgres.blomqowhgrfgkbeamqiw:hireloop123%40@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres


# ─────────────────────────────────────────────────────────────────────────────
# 2. AI — OpenAI
# ─────────────────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
# The platform uses gpt-4o-mini for all AI features (resume analysis,
# mock interviews, cover letters, skill radar, learning roadmaps).
#
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=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


# ─────────────────────────────────────────────────────────────────────────────
# 3. AUTHENTICATION — JWT Secrets
# ─────────────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
# Must be at least 32 characters. Keep secret — used to sign all user sessions.
#
SESSION_SECRET=XdRgbxbywVCT6J6TsQ8GawpQNT5i4pPx6pzRcAUU4nT1M5Hq8JdM29J/yRBv+fK92ZbW2H04fJIEB9MePkPQMw==
JWT_REFRESH_SECRET=eNemGzx/J7c0keAikX7dH1b4bFCgTmjK0watN3usH3p+YZbLZECfHN0cFiF/RXlex9rMAxuBiREQ0sGQU+zJsg==


# ─────────────────────────────────────────────────────────────────────────────
# 4. EMAIL — Resend
# ─────────────────────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
# Used for: job approval/rejection emails to recruiters, status notifications.
# EMAIL_FROM must be from a verified domain in your Resend account.
# For testing you can use: onboarding@resend.dev (only sends to your own email)
#
RESEND_API_KEY=re_KqvMM3rt_2U82BTPbf2LQimSdt69ogkAE
EMAIL_FROM=noreply@hireloop.com


# ─────────────────────────────────────────────────────────────────────────────
# 5. PAYMENTS — Stripe
# ─────────────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_ / pk_test_) for development.
# STRIPE_WEBHOOK_SECRET: get from Stripe Dashboard → Webhooks → your endpoint
#
# Pricing (configured in code):
#   listing_fee     = ₹999  (recruiter job post fee)
#   premium_monthly = ₹299  (student premium — monthly)
#   premium_yearly  = ₹2499 (student premium — yearly)
#
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...


# ─────────────────────────────────────────────────────────────────────────────
# 6. GOOGLE OAUTH — Sign in with Google
# ─────────────────────────────────────────────────────────────────────────────
# Setup at: https://console.cloud.google.com/
#   1. Create a project → APIs & Services → Credentials → Create OAuth 2.0 Client
#   2. Application type: Web application
#   3. Authorized redirect URIs:
#      - http://localhost:3001/api/auth/google/callback  (local dev)
#      - https://yourdomain.com/api/auth/google/callback (production)
#
GOOGLE_CLIENT_ID=816385652364-dske9418ts4ut74k3chva9fuqgnbnm9t.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=816385652364-dske9418ts4ut74k3chva9fuqgnbnm9t.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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


# ─────────────────────────────────────────────────────────────────────────────
# 7. GITHUB OAUTH — GitHub profile sync (optional)
# ─────────────────────────────────────────────────────────────────────────────
# Setup at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Callback URL: http://localhost:3001/api/auth/github/callback
#
GITHUB_CLIENT_ID=Iv1....
GITHUB_CLIENT_SECRET=your-github-client-secret


# ─────────────────────────────────────────────────────────────────────────────
# 8. FILE STORAGE — Cloudinary (optional — for PDF resume uploads)
# ─────────────────────────────────────────────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard
# Currently not implemented — placeholder for future PDF upload feature.
#
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret


# ─────────────────────────────────────────────────────────────────────────────
# 9. SERVER — Runtime settings
# ─────────────────────────────────────────────────────────────────────────────
# PORT: backend API server port (default 3001)
# NODE_ENV: "development" | "production"
# FRONTEND_URL: your deployed frontend URL (used in email links)
#
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173


# ─────────────────────────────────────────────────────────────────────────────
# 10. FRONTEND — Vite environment variables
# ─────────────────────────────────────────────────────────────────────────────
# These are read by Vite at BUILD TIME and exposed to the browser.
# VITE_ prefix is required for Vite to expose them.
#
# VITE_API_URL: URL of your backend API (used by the React frontend)
#   - Local dev: empty string "" (Vite proxy handles /api → localhost:3001)
#   - Production: https://api.yourdomain.com
#
VITE_API_URL=/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

DATABASE_URL=postgresql://postgres.blomqowhgrfgkbeamqiw:hireloop123%40@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

